{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/E-AI-MODEL/EAT-inline/schemas/registry-entry.schema.json",
  "title": "EAT Inline registry entry",
  "description": "A storage-neutral registry record for resolving an EAT Inline type/key pair.",
  "type": "object",
  "required": ["type", "key", "label", "canonical_id"],
  "properties": {
    "type": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "key": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "canonical_id": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "same_as": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "uniqueItems": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
