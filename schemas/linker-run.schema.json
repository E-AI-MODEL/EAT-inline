{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/E-AI-MODEL/EAT-inline/schemas/linker-run.schema.json",
  "title": "EAT Inline recorded model-linker run",
  "description": "A provenance-complete set of model predictions produced from plain text and replayed by the deterministic benchmark.",
  "type": "object",
  "required": ["schema_version", "dataset", "input", "model", "runner", "cases"],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "dataset": {
      "type": "object",
      "required": ["name", "sha256", "registry_sha256"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "registry_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      },
      "additionalProperties": false
    },
    "input": {
      "const": "plain_text",
      "description": "The model input boundary. Author-written EAT text and gold IDs are excluded."
    },
    "model": {
      "type": "object",
      "required": ["name", "version", "source"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1,
          "format": "uri"
        }
      },
      "additionalProperties": false
    },
    "runner": {
      "type": "object",
      "required": ["source", "commit", "command", "parameters"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1,
          "format": "uri"
        },
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{7,40}$"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case"
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "cost": {
      "type": "object",
      "required": ["model_calls", "estimated_tokens"],
      "properties": {
        "model_calls": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_tokens": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "mention": {
      "type": "object",
      "required": ["label", "start", "end", "type", "key"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 1,
          "description": "Exclusive character offset in plain_text."
        },
        "type": {
          "$ref": "#/$defs/identifier"
        },
        "key": {
          "$ref": "#/$defs/identifier"
        }
      },
      "additionalProperties": false
    },
    "case": {
      "type": "object",
      "required": ["id", "mentions", "cost"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mentions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/mention"
          }
        },
        "cost": {
          "$ref": "#/$defs/cost"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
